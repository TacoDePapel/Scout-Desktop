{
  "name": "scout-desktop",
  "version": "2.1.1",
  "description": "Scout — AI workflow capture by Orage AI Agency",
  "main": "main.js",
  "author": "Orage AI Agency <team@orage.agency>",
  "scripts": {
    "start": "electron .",
    "gen-icon": "node scripts/gen-icon.js",
    "dist": "npm run gen-icon && electron-builder",
    "dist:win": "npm run gen-icon && electron-builder --win",
    "dist:mac": "npm run gen-icon && electron-builder --mac",
    "dist:linux": "npm run gen-icon && electron-builder --linux",
    "dist:all": "npm run gen-icon && electron-builder -mwl"
  },
  "build": {
    "appId": "agency.orage.scout",
    "productName": "Scout",
    "copyright": "Copyright © 2025 Orage AI Agency",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "app.css",
      "build/icon.png",
      "build/trayTemplate.png",
      "build/trayTemplate@2x.png"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "artifactName": "Scout-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Scout",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "Scout-mac-${arch}.${ext}",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Scout records your microphone to capture narration for skill guides.",
        "NSCameraUsageDescription": "Scout does not use the camera.",
        "NSScreenCaptureDescription": "Scout captures screenshots of your desktop for the screen monitor and for the agent to see what is on screen."
      }
    },
    "dmg": {
      "title": "Scout ${version}",
      "writeUpdateInfo": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Office",
      "icon": "build/icon.png",
      "synopsis": "AI workflow capture and agent for your desktop",
      "artifactName": "Scout-linux-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
